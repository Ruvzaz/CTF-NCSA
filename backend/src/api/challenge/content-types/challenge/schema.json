{
  "kind": "collectionType",
  "collectionName": "challenges",
  "info": {
    "singularName": "challenge",
    "pluralName": "challenges",
    "displayName": "Challenge"
  },
  "options": { "draftAndPublish": true },
  "attributes": {
    "title": { "type": "string", "required": true },
    "slug": { "type": "uid", "targetField": "title", "required": true },
    "description": { "type": "richtext" },
    "flag": { "type": "string", "required": true, "private": true },
    "points": { "type": "integer", "required": true, "default": 100 },
    "difficulty": { "type": "enumeration", "enum": ["Easy", "Medium", "Hard", "Insane"] },
    "category": { "type": "relation", "relation": "manyToOne", "target": "api::category.category" },
    "hints": { "type": "json" },
    "solveCount": { "type": "integer", "default": 0 },
    "firstBlood": { "type": "string" }
  }
}
