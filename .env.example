# ============================================================
# NCSA CTF — Production Environment Variables Template
# คัดลอกไฟล์นี้เป็น .env แล้วเติมค่าจริงลงไป
# ห้าม commit ไฟล์ .env ขึ้น Git โดยเด็ดขาด!
# สร้าง secret ด้วย: node -e "console.log(require('crypto').randomBytes(24).toString('base64'))"
# ============================================================

# --- Server ---
HOST=0.0.0.0
PORT=1337

# --- Strapi Core Secrets ---
APP_KEYS=key1_base64,key2_base64,key3_base64,key4_base64
API_TOKEN_SALT=your_api_token_salt_here
ADMIN_JWT_SECRET=your_admin_jwt_secret_here
TRANSFER_TOKEN_SALT=your_transfer_token_salt_here
ENCRYPTION_KEY=your_encryption_key_here
JWT_SECRET=your_jwt_secret_here

# --- Database (SQLite default) ---
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db
DATABASE_HOST=
DATABASE_PORT=
DATABASE_NAME=
DATABASE_USERNAME=
DATABASE_PASSWORD=
DATABASE_SSL=false

# --- Next.js Frontend URLs ---
NEXT_PUBLIC_STRAPI_URL=http://YOUR_SERVER_IP:1337
STRAPI_URL=http://backend:1337

# --- API Token (ไม่จำเป็นสำหรับ Public access) ---
STRAPI_API_TOKEN=
